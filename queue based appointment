#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 100

struct Patient {
    char name[50];
};

struct Patient queue[MAX];
int front = -1, rear = -1;

int isFull() {
    return rear == MAX - 1;
}

int isEmpty() {
    return front == -1 || front > rear;
}

void addPatient() {
    if(isFull()) {
        printf("Queue is full!\n");
        return;
    }

    struct Patient p;
    printf("Enter patient name: ");
    scanf("%s", p.name);

    if(front == -1) front = 0;
    rear++;
    queue[rear] = p;

    printf("Patient added.\n");
}

void viewNextPatient() {
    if(isEmpty()) {
        printf("No patients in queue.\n");
        return;
    }

    printf("Next patient: %s\n", queue[front].name);
}

void servePatient() {
    if(isEmpty()) {
        printf("No patients to serve.\n");
        return;
    }

    printf("Serving patient: %s\n", queue[front].name);
    front++;
}

void displayPatients() {
    if(isEmpty()) {
        printf("No patients waiting.\n");
        return;
    }

    printf("Waiting patients:\n");
    for(int i = front; i <= rear; i++) {
        printf("%s\n", queue[i].name);
    }
}

int main() {
    int choice;

    while(1) {
        printf("\n--- Clinic Appointment System ---\n");
        printf("1. Add Patient\n");
        printf("2. View Next Patient\n");
        printf("3. Serve Patient\n");
        printf("4. Display All Patients\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1: addPatient(); break;
            case 2: viewNextPatient(); break;
            case 3: servePatient(); break;
            case 4: displayPatients(); break;
            case 5: exit(0);
            default: printf("Invalid choice\n");
        }
    }

    return 0;
}
