#include <stdio.h>

#define MAX 20

int adj[MAX][MAX];
int vertices = 0;

void createGraph() {
    int i, j;

    printf("Enter number of vertices: ");
    scanf("%d", &vertices);

    for(i = 0; i < vertices; i++) {
        for(j = 0; j < vertices; j++) {
            adj[i][j] = 0;
        }
    }

    printf("Graph created with %d vertices.\n", vertices);
}

void insertEdge() {
    int v1, v2;

    printf("Enter first vertex: ");
    scanf("%d", &v1);

    printf("Enter second vertex: ");
    scanf("%d", &v2);

    if(v1 >= vertices || v2 >= vertices) {
        printf("Invalid vertex!\n");
        return;
    }

    adj[v1][v2] = 1;
    adj[v2][v1] = 1; // because graph is undirected

    printf("Edge inserted between %d and %d\n", v1, v2);
}

void printMatrix() {
    int i, j;

    printf("\nAdjacency Matrix:\n");

    for(i = 0; i < vertices; i++) {
        for(j = 0; j < vertices; j++) {
            printf("%d ", adj[i][j]);
        }
        printf("\n");
    }
}

void adjacentVertices() {
    int v, i;

    printf("Enter vertex: ");
    scanf("%d", &v);

    if(v >= vertices) {
        printf("Invalid vertex!\n");
        return;
    }

    printf("Vertices adjacent to %d: ", v);

    for(i = 0; i < vertices; i++) {
        if(adj[v][i] == 1) {
            printf("%d ", i);
        }
    }

    printf("\n");
}

int main() {
    int choice;

    while(1) {
        printf("\n--- GRAPH MENU ---\n");
        printf("1. Create Graph\n");
        printf("2. Insert Edge\n");
        printf("3. Print Adjacency Matrix\n");
        printf("4. List Adjacent Vertices\n");
        printf("5. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                createGraph();
                break;

            case 2:
                insertEdge();
                break;

            case 3:
                printMatrix();
                break;

            case 4:
                adjacentVertices();
                break;

            case 5:
                printf("Exiting program...\n");
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }

    return 0;
}
