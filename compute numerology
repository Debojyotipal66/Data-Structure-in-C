#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

struct Node {
    char name[50];
    int number;
    struct Node* next;
};

struct Node* head = NULL;

int getValue(char c) {
    c = toupper(c);
    if(c >= 'A' && c <= 'I') return c - 'A' + 1;
    if(c >= 'J' && c <= 'R') return c - 'J' + 1;
    if(c >= 'S' && c <= 'Z') return c - 'S' + 1;
    return 0;
}

int reduceNumber(int num) {
    while(num > 9) {
        int sum = 0;
        while(num > 0) {
            sum += num % 10;
            num /= 10;
        }
        num = sum;
    }
    return num;
}

int numerologyNumber(char name[]) {
    int sum = 0;
    for(int i = 0; name[i]; i++) {
        if(isalpha(name[i])) {
            sum += getValue(name[i]);
        }
    }
    return reduceNumber(sum);
}

void addName(char name[]) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    strcpy(newNode->name, name);
    newNode->number = numerologyNumber(name);
    newNode->next = head;
    head = newNode;
}

void display() {
    struct Node* temp = head;
    while(temp != NULL) {
        printf("Name: %s | Number: %d\n", temp->name, temp->number);
        temp = temp->next;
    }
}

void frequencyAnalysis() {
    int freq[10] = {0};
    struct Node* temp = head;

    while(temp != NULL) {
        freq[temp->number]++;
        temp = temp->next;
    }

    printf("Numerology Frequency:\n");
    for(int i = 1; i <= 9; i++) {
        if(freq[i] > 0) {
            printf("Number %d: %d times\n", i, freq[i]);
        }
    }
}

int main() {
    int choice;
    char name[50];

    while(1) {
        printf("\n--- Numerology System ---\n");
        printf("1. Add Name\n");
        printf("2. Display Data\n");
        printf("3. Frequency Analysis\n");
        printf("4. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Enter name: ");
                scanf("%s", name);
                addName(name);
                break;

            case 2:
                display();
                break;

            case 3:
                frequencyAnalysis();
                break;

            case 4:
                exit(0);

            default:
                printf("Invalid choice\n");
        }
    }

    return 0;
}
