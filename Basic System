#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Crop {
    char cropName[50];
    char soilType[50];
    int irrigationTime; // in hours
    struct Crop* next;
};

struct Crop* createNode(char crop[], char soil[], int time) {
    struct Crop* newNode = (struct Crop*)malloc(sizeof(struct Crop));

    strcpy(newNode->cropName, crop);
    strcpy(newNode->soilType, soil);
    newNode->irrigationTime = time;
    newNode->next = NULL;

    return newNode;
}

void insertCrop(struct Crop** head, char crop[], char soil[], int time) {
    struct Crop* newNode = createNode(crop, soil, time);

    if (*head == NULL) {
        *head = newNode;
        return;
    }

    struct Crop* temp = *head;
    while (temp->next != NULL) {
        temp = temp->next;
    }

    temp->next = newNode;
}

void recommendIrrigation(struct Crop* head, char crop[], char soil[]) {
    struct Crop* temp = head;

    while (temp != NULL) {
        if (strcmp(temp->cropName, crop) == 0 &&
            strcmp(temp->soilType, soil) == 0) {

            printf("\nRecommended irrigation time: %d hours\n", temp->irrigationTime);
            return;
        }

        temp = temp->next;
    }

    printf("\nNo data found for this crop and soil type.\n");
}

void display(struct Crop* head) {
    struct Crop* temp = head;

    printf("\nCrop Data:\n");
    while (temp != NULL) {
        printf("Crop: %s | Soil: %s | Irrigation Time: %d hours\n",
               temp->cropName, temp->soilType, temp->irrigationTime);
        temp = temp->next;
    }
}

int main() {
    struct Crop* head = NULL;

    insertCrop(&head, "Wheat", "Loamy", 6);
    insertCrop(&head, "Rice", "Clay", 10);
    insertCrop(&head, "Maize", "Sandy", 5);
    insertCrop(&head, "Cotton", "Black", 8);

    display(head);

    char crop[50], soil[50];

    printf("\nEnter crop name: ");
    scanf("%s", crop);

    printf("Enter soil type: ");
    scanf("%s", soil);

    recommendIrrigation(head, crop, soil);

    return 0;
}
